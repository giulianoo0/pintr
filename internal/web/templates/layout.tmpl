{{/* Shared building blocks. Every page template starts with "head"; simple
     pages use "pagetop"/"pagebottom" which add the standard header, the
     mobile slide-down menu, <main>, and the footer + site script. */}}

{{define "head" -}}
<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{.Title}}</title>
<meta name="description" content="pintr turns your own ChatGPT login into a Codex image generator any MCP client can call.">
<meta name="theme-color" content="#2b6cb0">
<link rel="icon" type="image/svg+xml" href="/static/favicon.svg">
<link rel="icon" type="image/png" sizes="512x512" href="/static/favicon.png">
<link rel="apple-touch-icon" href="/static/favicon.png">
<meta property="og:type" content="website">
<meta property="og:site_name" content="pintr">
<meta property="og:title" content="{{.Title}}">
<meta property="og:description" content="Codex image generation over MCP — your own ChatGPT login, any MCP client.">
<meta property="og:url" content="{{absURL "/"}}">
<meta property="og:image" content="{{absURL "/static/banner.png"}}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{.Title}}">
<meta name="twitter:description" content="Codex image generation over MCP — your own ChatGPT login, any MCP client.">
<meta name="twitter:image" content="{{absURL "/static/banner.png"}}">
<link rel="preload" href="/static/fonts/geist-latin.woff2" as="font" type="font/woff2" crossorigin>
{{if plausibleScript}}<script async src="{{plausibleScript}}"></script>
<script>{{plausibleInit}}</script>
{{end}}{{if turnstileSiteKey}}<script async defer src="https://challenges.cloudflare.com/turnstile/v0/api.js"></script>
{{end}}<style>{{styles}}</style></head><body>
{{- end}}

{{define "logo"}}<a href="/" class="logo"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5" fill="#2b6cb0"/><circle cx="9" cy="9.5" r="1.9" fill="#fff"/><path d="M4.5 17.5l4.3-4.3 3 3 3.4-3.9 4.3 5z" fill="#fff"/></svg><span>pintr</span></a>{{end}}

{{define "github"}}<a class="gh" href="https://github.com/giulianoo0/pintr" target="_blank" rel="noopener" title="source on github" aria-label="source on github"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 016 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"/></svg></a>{{end}}

{{define "nav"}}{{template "github"}}{{if eq . "authed"}}<a href="/dashboard">dashboard</a>{{else}}<a href="/login">log in</a><a href="/signup" class="btn-sm">sign up</a>{{end}}{{end}}

{{define "menubtn"}}<button class="menu-btn" type="button" aria-label="menu" aria-controls="site-menu" aria-expanded="false"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"/></svg></button>{{end}}

{{define "footer"}}<footer><span class="footer-links"><a href="/llms.txt">llms.txt</a> · <a href="https://github.com/giulianoo0/pintr" target="_blank" rel="noopener">source</a></span><span class="footer-version">v{{version}}{{if commitURL}} · <a href="{{commitURL}}" target="_blank" rel="noopener" title="{{commitURL}}">{{commitShort}}</a>{{end}}</span></footer>{{end}}

{{define "csrf"}}<input type="hidden" name="csrf" value="{{.}}">{{end}}

{{define "turnstile"}}{{if turnstileSiteKey}}<div class="cf-turnstile" data-sitekey="{{turnstileSiteKey}}"></div>
{{end}}{{end}}

{{define "pagetop"}}{{template "head" .}}
<header>{{template "logo"}}<nav class="nav" aria-label="primary">{{template "nav" .Nav}}</nav>{{template "menubtn"}}</header>
<div class="menu" id="site-menu"><nav class="menu-items" aria-label="mobile">{{template "nav" .Nav}}<a href="/llms.txt">llms.txt</a></nav></div>
<main>{{end}}

{{define "pagebottom"}}</main>
{{template "footer"}}
<script>{{script}}</script>
</body></html>{{end}}
