{{/* Simple pages: landing, signup, login, generic message, new key, link flow,
     and the OAuth consent screen. The dashboard lives in dashboard.tmpl. */}}

{{define "index"}}{{template "pagetop" .}}
<div class="hero">
  <h1 class="hero-title">Codex image generation, over MCP.</h1>
  <p class="lead">pintr turns your own ChatGPT login into an image generator any
  MCP client can call.</p>
  <div class="cta"><a href="/signup" class="btn">create account</a> <a href="/login">log in</a></div>
</div>
<div class="cards">
  <div class="card"><h2>your own login</h2><p>sign in with ChatGPT through OAuth — no separate API key or billing. link several accounts and pintr spreads generation across them, failing over when one hits a limit.</p></div>
  <div class="card"><h2>encrypted by default</h2><p>generated images and uploads are encrypted at rest; the keys are returned once and never stored.</p></div>
  <div class="card"><h2>any mcp client</h2><p>connect Claude Code, OpenCode, PI, or any MCP client over HTTPS.</p></div>
</div>
{{template "pagebottom"}}{{end}}

{{define "signup"}}{{template "pagetop" .}}
<h1>create account</h1>
<form method="post" action="/signup">
{{template "csrf" .CSRF}}
<input type="email" name="email" placeholder="email" aria-label="email" autofocus required>
<input type="password" name="password" placeholder="password (8+ chars)" aria-label="password (8+ characters)" required>
{{template "turnstile"}}
<button type="submit">create account</button>
</form>
<p><a href="/login">already have an account? log in</a></p>
{{template "pagebottom"}}{{end}}

{{define "login"}}{{template "pagetop" .}}
<h1>log in</h1>
<form method="post" action="/login">
{{template "csrf" .CSRF}}
<input type="hidden" name="next" value="{{.Next}}">
<input type="email" name="email" placeholder="email" autofocus required>
<input type="password" name="password" placeholder="password" required>
{{template "turnstile"}}
<button type="submit">log in</button>
</form>
<p><a href="/signup">create an account</a></p>
{{template "pagebottom"}}{{end}}

{{define "message"}}{{template "pagetop" .}}
{{if .Error}}<p class="err">{{.Error}}</p>{{end}}
<p><a href="{{.BackHref}}">{{.BackText}}</a></p>
{{template "pagebottom"}}{{end}}

{{define "newkey"}}{{template "pagetop" .}}
<h1>new access key</h1>
<p>copy it now — it is shown only once:</p>
<p><code>{{.Key}}</code></p>
<p><a href="/dashboard">back to dashboard</a></p>
{{template "pagebottom"}}{{end}}

{{define "linkstart"}}{{template "pagetop" .}}
<h1>link a chatgpt account</h1>
<p>1. sign in to openai:</p>
<p><a href="{{.AuthorizeURL}}" target="_blank" rel="noopener" class="btn">sign in with openai</a></p>
<p>2. your browser then tries to open a <code>localhost:1455</code> page and fails — that is expected. copy the full url from the address bar and paste it here:</p>
<form method="post" action="/link/finish">
{{template "csrf" .CSRF}}
<input type="hidden" name="state" value="{{.State}}">
<textarea name="callback_url" rows="4" placeholder="http://localhost:1455/auth/callback?code=..." aria-label="callback url from localhost:1455" autofocus></textarea>
{{template "turnstile"}}
<button type="submit">finish linking</button>
</form>
{{template "pagebottom"}}{{end}}

{{define "consent"}}{{template "pagetop" .}}
<h1>authorize mcp client</h1>
<p>an mcp client wants to connect to pintr as <b>{{.Email}}</b>.</p>
<form method="post" action="/authorize">
{{range .Hidden}}<input type="hidden" name="{{.Name}}" value="{{.Value}}">{{end}}
{{template "csrf" .CSRF}}
{{template "turnstile"}}
<button type="submit">allow</button>
</form>
<p><a href="/dashboard">cancel</a></p>
{{template "pagebottom"}}{{end}}
