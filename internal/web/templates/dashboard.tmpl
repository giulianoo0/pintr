{{/* The tabbed dashboard. Radios come first, then the header (sliding tabs +
     logout), the mobile menu, then the panes in <main> — the CSS-only tabs
     (#radio:checked ~ …) need everything after the radios. */}}

{{define "usage"}}<div class="limits">{{if .}}{{range .}}<div class="lim"><span class="lim-k">{{.Label}}</span><span class="bar" aria-hidden="true"><span class="{{.Class}}" style="width:{{.Pct}}%"></span></span><span class="lim-v">{{.Pct}}% left</span></div>{{end}}{{else}}no rate-limit data{{end}}</div>{{end}}

{{define "dashboard"}}{{template "head" .}}
<input class="dtab" type="radio" name="dtab" id="t-accounts" checked>
<input class="dtab" type="radio" name="dtab" id="t-keys">
<input class="dtab" type="radio" name="dtab" id="t-connect">
<input class="dtab" type="radio" name="dtab" id="t-data">
<header>{{template "logo"}}
<nav class="tabs" aria-label="dashboard sections"><span class="slider"></span><label for="t-accounts">accounts</label><label for="t-keys">keys</label><label for="t-connect">connect</label><label for="t-data">data</label></nav>
<form method="post" action="/logout" class="logout">{{template "csrf" .CSRF}}<button type="submit" class="link">log out</button></form>{{template "menubtn"}}</header>
<div class="menu" id="site-menu"><nav class="menu-items" aria-label="mobile"><label for="t-accounts">accounts</label><label for="t-keys">keys</label><label for="t-connect">connect</label><label for="t-data">data</label><a href="/llms.txt">llms.txt</a><form method="post" action="/logout">{{template "csrf" .CSRF}}<button type="submit" class="link">log out</button></form></nav></div>
<main>
<h1 style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0">pintr dashboard</h1>
<section class="tabpane" id="p-accounts">
{{if not .Accounts}}<p class="err">no chatgpt account linked yet. image generation will fail until you add one.</p>{{end}}
{{range .Accounts}}<div class="acct"><div class="acct-hd"><b>{{.Email}}</b> <span class="muted">{{.Plan}}{{if .IsDefault}} <span class="ok">· default</span>{{end}}</span></div>
{{- if .HasUsage}}{{template "usage" .Windows}}<div class="fresh" data-age="{{.FreshAge}}" data-left="{{.FreshLeft}}"></div>{{else}}<div class="limits">limits unavailable</div>{{end -}}
<div class="acct-ft">{{if not .IsDefault}}<form method="post" action="/accounts/default" style="display:inline">{{template "csrf" $.CSRF}}<input type="hidden" name="id" value="{{.ID}}"><button type="submit" class="link" aria-label="make {{.Email}} the default account">make default</button></form> · {{end}}<form method="post" action="/accounts/remove" style="display:inline" data-confirm="remove this account?">{{template "csrf" $.CSRF}}<input type="hidden" name="id" value="{{.ID}}"><button type="submit" class="link danger" aria-label="remove account {{.Email}}">remove</button></form></div></div>
{{end}}
<form method="post" action="/link/start" style="display:inline">{{template "csrf" .CSRF}}<button type="submit">link a chatgpt account</button></form>
{{if .Accounts}} <form method="post" action="/usage/refresh" style="display:inline">{{template "csrf" .CSRF}}<button type="submit" class="link">refresh limits</button></form>
<p class="muted">limits are cached ~30 min; refresh (or the get_usage tool) fetches fresh.</p>{{end}}
</section>
<section class="tabpane" id="p-keys">
<p class="muted">access keys authenticate scripts/clients with <code>Authorization: Bearer &lt;key&gt;</code>. mcp clients that logged in through the browser oauth flow show up as "oauth" sessions — revoke any of them here.</p>
{{if or .Keys .OAuthSessions}}<div class="table-wrap"><table><tr><th scope="col">key</th><th scope="col">name</th><th scope="col">created</th><th scope="col">actions</th></tr>
{{range .Keys}}<tr><td><code>{{.Prefix}}…</code></td><td>{{.Name}}</td><td>{{shortDate .CreatedAt}}</td><td><form method="post" action="/keys/remove" style="display:inline">{{template "csrf" $.CSRF}}<input type="hidden" name="id" value="{{.ID}}"><button type="submit" class="link danger" aria-label="revoke access key {{.Prefix}}">revoke</button></form></td></tr>
{{end}}{{range .OAuthSessions}}<tr><td><span class="muted">oauth session</span></td><td>oauth</td><td>{{shortDate .CreatedAt}}</td><td><form method="post" action="/sessions/remove" style="display:inline">{{template "csrf" $.CSRF}}<input type="hidden" name="id" value="{{.ID}}"><button type="submit" class="link danger" aria-label="revoke oauth session">revoke</button></form></td></tr>
{{end}}</table></div>{{end}}
<div class="keys-actions">
<form method="post" action="/keys/create" class="keyform">{{template "csrf" .CSRF}}<input type="text" name="name" placeholder="key name (optional)"><button type="submit">new access key</button></form>
<form method="post" action="/tokens/revoke" data-confirm="sign out all mcp clients? they will have to authorize again.">{{template "csrf" .CSRF}}<button type="submit" class="link danger">revoke all mcp tokens</button></form>
</div>
</section>
<section class="tabpane" id="p-connect">
<p>add pintr to your mcp client by url: <code>{{.Resource}}</code>. on first connect your browser opens; you log in to pintr and click allow, and the client keeps its own token (auto-refreshed). prefer a static key? create one in the keys tab and pass it as an <code>Authorization: Bearer pintr_YOURKEY</code> header.</p>
<input class="dtab" type="radio" name="ctab" id="c-claude" checked>
<input class="dtab" type="radio" name="ctab" id="c-opencode">
<input class="dtab" type="radio" name="ctab" id="c-pi">
<input class="dtab" type="radio" name="ctab" id="c-codex">
<input class="dtab" type="radio" name="ctab" id="c-antigravity">
<input class="dtab" type="radio" name="ctab" id="c-grok">
<input class="dtab" type="radio" name="ctab" id="c-other">
<div class="htabs-wrap"><nav class="htabs"><span class="hslider"></span><label for="c-claude">Claude Code</label><label for="c-opencode">OpenCode</label><label for="c-pi">PI</label><label for="c-codex">Codex</label><label for="c-antigravity">Antigravity</label><label for="c-grok">Grok Build</label><label for="c-other">Other</label></nav></div>
<div class="hpane" id="hp-claude">
<pre><code>claude mcp add --transport http pintr {{.Resource}}</code></pre>
<p class="muted">with an access key instead of oauth: append <code>--header "Authorization: Bearer pintr_YOURKEY"</code></p>
</div>
<div class="hpane" id="hp-opencode">
<p><code>opencode mcp add</code> (interactive), or in <code>opencode.json</code>:</p>
<pre><code>{
  "mcp": {
    "pintr": {
      "type": "remote",
      "url": "{{.Resource}}",
      "enabled": true
    }
  }
}</code></pre>
<p class="muted">access key instead of oauth: add <code>"headers": {"Authorization": "Bearer pintr_YOURKEY"}</code></p>
</div>
<div class="hpane" id="hp-pi">
<p>in the mcp config (<code>.mcp.json</code> / pi settings):</p>
<pre><code>{
  "mcp": {
    "pintr": {
      "type": "remote",
      "url": "{{.Resource}}"
    }
  }
}</code></pre>
<p class="muted">access key instead of oauth: add <code>"headers": {"Authorization": "Bearer pintr_YOURKEY"}</code></p>
</div>
<div class="hpane" id="hp-codex">
<pre><code>codex mcp add pintr --url {{.Resource}}</code></pre>
<p>or in <code>~/.codex/config.toml</code>:</p>
<pre><code>[mcp_servers.pintr]
url = "{{.Resource}}"
# optional access key instead of oauth:
# bearer_token_env_var = "PINTR_KEY"</code></pre>
</div>
<div class="hpane" id="hp-antigravity">
<p>shared cli + ide config at <code>~/.gemini/config/mcp_config.json</code> (note <code>serverUrl</code>, not <code>url</code>):</p>
<pre><code>{
  "mcpServers": {
    "pintr": {
      "serverUrl": "{{.Resource}}"
    }
  }
}</code></pre>
<p class="muted">access key instead of oauth: add <code>"headers": {"Authorization": "Bearer pintr_YOURKEY"}</code></p>
</div>
<div class="hpane" id="hp-grok">
<p>grok build reads claude-style mcp config (<code>.mcp.json</code> in the project):</p>
<pre><code>{
  "mcpServers": {
    "pintr": {
      "type": "http",
      "url": "{{.Resource}}"
    }
  }
}</code></pre>
<p class="muted">for grok.com chat: grok.com/connectors → new connector → custom → paste the url.</p>
</div>
<div class="hpane" id="hp-other">
<p>any mcp client with remote (streamable http) support works: add a remote mcp server pointing at <code>{{.Resource}}</code>. if the client can't run the browser oauth flow, pass an access key header (works everywhere, including curl):</p>
<pre><code>Authorization: Bearer pintr_YOURKEY</code></pre>
<p class="muted">full endpoint + tool reference for agents: <a href="/llms.txt">/llms.txt</a></p>
</div>
</section>
<section class="tabpane" id="p-data">
<p class="whoami">signed in as <span class="email" title="hover to reveal">{{.Email}}</span></p>
<h2>stored data</h2>
{{if not .AssetsConfigured}}<p>asset storage is not configured on this server.</p>
{{else}}<p class="muted">everything is stored encrypted; decryption keys are only returned at generation/upload time and never saved here, so nothing can be viewed from this page. expired objects are permanently deleted from storage.</p>
<div class="stored">
<div class="stored-row"><span>{{if .AssetCountKnown}}<b>{{.AssetCount}}</b> generated image(s){{else}}generated images: count unavailable{{end}} <span class="muted">· auto-delete 24h after generation</span></span>
<form method="post" action="/assets/purge" data-confirm="permanently delete ALL your generated images? this cannot be undone.">{{template "csrf" .CSRF}}<input type="hidden" name="kind" value="generated"><button type="submit" class="link danger">delete all generated images</button></form></div>
<div class="stored-row"><span>{{if .UploadCountKnown}}<b>{{.UploadCount}}</b> reference upload(s){{else}}reference uploads: count unavailable{{end}} <span class="muted">· auto-delete 1h after upload</span></span>
<form method="post" action="/assets/purge" data-confirm="permanently delete ALL your reference uploads? this cannot be undone.">{{template "csrf" .CSRF}}<input type="hidden" name="kind" value="uploads"><button type="submit" class="link danger">delete all reference uploads</button></form></div>
</div>
{{end}}
<h2 class="danger">danger zone</h2>
<p>delete your account and <b>everything</b> tied to it — linked chatgpt accounts, access keys, sessions, and all stored images. permanent, cannot be undone.</p>
<form method="post" action="/account/delete" data-confirm="Delete your account and ALL data permanently? This cannot be undone.">{{template "csrf" .CSRF}}<button type="submit" class="danger-btn">delete my account</button></form>
</section>
</main>
{{template "footer"}}
<script>{{script}}</script>
</body></html>{{end}}
