# pintr hosted (http) mode configuration.
# copy to .env on the server and fill in. loaded by systemd EnvironmentFile.

# public https base url that clients reach (no trailing slash)
PINTR_PUBLIC_URL=https://pintr.giuli.dev

# sqlite database file
PINTR_DB=/home/blumo/pintr/pintr.db

# master secret, 32+ random chars. signs oauth tokens AND encrypts stored
# chatgpt tokens. keep it secret and STABLE — rotating it makes every linked
# account undecryptable (users must re-link).
PINTR_SECRET=

# optional: override the codex driver model (default gpt-5.6-terra)
# PINTR_IMAGE_MODEL=gpt-5.6-terra

# --- object storage for generated images (S3-compatible, e.g. Cloudflare R2) ---
# generated pngs are encrypted per-image before upload; the key is returned once
# in the tool response and never stored, so the bucket only holds ciphertext.
PINTR_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
PINTR_S3_BUCKET=
PINTR_S3_ACCESS_KEY_ID=
PINTR_S3_SECRET_ACCESS_KEY=
PINTR_S3_REGION=auto
