# pintr hosted (http) mode configuration.
# copy to .env on the server and fill in. loaded by systemd EnvironmentFile.

# public https base url that clients reach (no trailing slash)
PINTR_PUBLIC_URL=https://pintr.giuli.dev

# sqlite database file
PINTR_DB=/home/blumo/pintr/pintr.db

# master secret, 32+ random chars. signs oauth tokens AND encrypts stored
# chatgpt tokens. keep it secret and STABLE — rotating it makes every linked
# account undecryptable (users must re-link).
PINTR_SECRET=

# optional: override the codex driver model (default gpt-5.6-terra)
# PINTR_IMAGE_MODEL=gpt-5.6-terra

# --- object storage for generated images (S3-compatible, e.g. Cloudflare R2) ---
# generated pngs are encrypted per-image before upload; the key is returned once
# in the tool response and never stored, so the bucket only holds ciphertext.
PINTR_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
PINTR_S3_BUCKET=
PINTR_S3_ACCESS_KEY_ID=
PINTR_S3_SECRET_ACCESS_KEY=
PINTR_S3_REGION=auto
# optional: a custom domain bound to the bucket (r2 public domain). when set,
# download urls are presigned for this host with the object key as the path
# (no bucket prefix), e.g. https://pintr-assets.giuli.dev/assets/<user>/<id>?...
PINTR_S3_PUBLIC_BASE=https://pintr-assets.giuli.dev

# --- anonymous analytics (Plausible, optional) ---
# both unset = no analytics at all. when set:
# - PINTR_PLAUSIBLE_DOMAIN enables server-side event counts (signup,
#   chatgpt_linked, generate_image, get_usage, image_view, reference_upload,
#   mcp_client_authorized) via the Plausible Events API. events carry only a
#   name — no user id, IP, prompt, or any identifiable data.
# - PINTR_PLAUSIBLE_SCRIPT (the script url from your Plausible snippet) adds
#   the page-view script tag to dashboard pages.
# PINTR_PLAUSIBLE_DOMAIN=pintr.giuli.dev
# PINTR_PLAUSIBLE_SCRIPT=https://plausible.io/js/pa-XXXXXXXXXXXX.js

# --- Cloudflare Turnstile (optional captcha) ---
# both unset = no captcha anywhere. when both are set, signup, login, the
# chatgpt link form, and the mcp consent page show a Turnstile widget and the
# token is verified server-side (siteverify) before the action runs.
# PINTR_TURNSTILE_SITE_KEY=
# PINTR_TURNSTILE_SECRET_KEY=
